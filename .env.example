PORT=3000
LOG_LEVEL=info
AUTH_SERVER_URL=http://localhost:8080/realms/finance
# When the MCP server runs in Docker but tokens use localhost issuer, fetch JWKS from the internal host:
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080/realms/finance
PUBLIC_BASE_URL=http://localhost:3000
# Full MCP resource URL for RFC 9728 `resource` (defaults to PUBLIC_BASE_URL + /mcp)
# MCP_RESOURCE_URL=http://localhost:3000/mcp
OAUTH_CLIENT_ID=mcp-client
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://keycloak:keycloak@localhost:5432/mcp_data
NSE_API_KEY=your_key_here
ALPHA_VANTAGE_KEY=your_key_here
FINNHUB_KEY=your_key_here
NEWSAPI_KEY=your_key_here
